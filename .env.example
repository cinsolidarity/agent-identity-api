# ── Wallet ───────────────────────────────────────────────────────────────────
# Required for POST /register (signs the mint transaction)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ── Alchemy ───────────────────────────────────────────────────────────────────
# Required for both endpoints (JSON-RPC provider)
# Free tier: https://dashboard.alchemy.com
ALCHEMY_API_KEY=YOUR_ALCHEMY_API_KEY_HERE

# ── Pinata IPFS ───────────────────────────────────────────────────────────────
# Required for POST /register (uploads metadata to IPFS)
# Generate a JWT at: https://app.pinata.cloud → API Keys → New Key
PINATA_JWT=YOUR_PINATA_JWT_HERE

# ── Server ────────────────────────────────────────────────────────────────────
# Optional. Defaults to 3000. Railway injects this automatically.
PORT=3000
